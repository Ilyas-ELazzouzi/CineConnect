NODE_ENV=production
PORT=3001

# In docker-compose, host is "db" (service name), not localhost.
DATABASE_URL=postgresql://postgres:postgres@db:5432/cineconnect

# Use strong random secrets in real usage.
JWT_SECRET=replace-with-strong-secret-at-least-16-chars
REFRESH_TOKEN_SECRET=replace-with-strong-secret-at-least-16-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Optional: OMDb API key for external movie data.
OMDB_API_KEY=

# In Docker mode, app and client share same origin.
CORS_ORIGINS=http://localhost:3001
