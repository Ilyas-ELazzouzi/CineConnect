# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/cineconnect

# JWT (min 16 caractères)
JWT_SECRET=your-secret-key-min-16-chars
JWT_EXPIRES_IN=7d

# OMDb API (optionnel, pour la recherche de films)
OMDB_API_KEY=

# CORS - origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Port du serveur
PORT=3001
